{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Scraping": {
    "UserAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36",
    "BrowserTimeoutMs": 60000,
    "MaxBatchConcurrency": 12,
    "MaxHttpConcurrency": 24,
    "MaxBrowserConcurrency": 4,
    "MaxSitemapConcurrency": 8
  },
  "AmazonCatalog": {
    "AuthoritativeCatalogDirectory": "",
    "AuthoritativeFilePaths": [],
    "AuthoritativeFilePatterns": [
      "*.txt",
      "*.csv",
      "*.tsv",
      "*.xml",
      "*.json",
      "*.jsonl"
    ],
    "CatalogDirectory": "",
    "FilePaths": [],
    "FilePatterns": [
      "*.txt",
      "*.csv",
      "*.tsv",
      "*.xml",
      "*.json",
      "*.jsonl"
    ],
    "AutoBootstrapIfMissing": true,
    "BootstrapMaxPages": 2500,
    "BootstrapMaxConcurrency": 8,
    "BootstrapUseBrowser": false,
    "BootstrapMaxRetryAttempts": 6,
    "BootstrapRetryBaseDelayMs": 750,
    "BootstrapRetryJitterMaxMs": 1500,
    "BootstrapRequestMinDelayMs": 150,
    "BootstrapRequestMaxDelayMs": 900,
    "BootstrapSeedUrls": [],
    "BootstrapSearchAliases": [],
    "BootstrapFilePrefix": "amazon-it-bootstrap-product",
    "CatalogFileReadConcurrency": 4
  },
  "CatalogRefresh": {
    "Enabled": true,
    "RunOnStartup": true,
    "InitialDelaySeconds": 15,
    "CheckIntervalMinutes": 180,
    "SnapshotStaleAfterMinutes": 180,
    "SnapshotRootDirectory": ""
  },
  "AllowedHosts": "*"
}
